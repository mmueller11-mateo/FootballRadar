@model CreateNationalTeamViewModel
@using FootballRadar.Admin.WebApp.Controllers
@using FootballRadar.Admin.WebApp.Models

<h2>Create new Nationalteam</h2>

<form method="post" action="@Url.Action(nameof(NationalTeamController.CreateNationalTeam), "NationalTeam")">
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <div class="form-group mb-3">
        <label>Name</label>
        <input type="text" name="Name" class="form-control" value="@Model?.Name" />
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Country</label>
        <select name="CountryId" class="form-control">
            <option value="">-- Please Choose --</option>
            @foreach (var country in Model.Countries)
            {
                if (country.Id == Model.CountryId)
                {
                    <option value="@country.Id" selected>@country.Name</option>
                }
                else
                {
                    <option value="@country.Id">@country.Name</option>
                }
            }
        </select>
        @Html.ValidationMessageFor(m => m.CountryId, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-3">
        <label>Level</label>
        <select name="Level" class="form-control">
            <option value="">-- Please Choose --</option>
            @foreach (var level in Model.Levels)
            {
                if (level == Model.Level)
                {
                    <option value="@level" selected>@level</option>
                }
                else
                {
                    <option value="@level">@level</option>
                }
            }
        </select>
        @Html.ValidationMessageFor(m => m.Level, "", new { @class = "text-danger" })
    </div>
    <button type="submit" class="btn btn-success">Create</button>
    <a class="btn btn-secondary" href="@Url.Action(nameof(NationalTeamController.NationalTeamsList), "NationalTeam")">
        Back to list
    </a>
</form>