@using FootballRadar.Admin.WebApp.Controllers
@using FootballRadar.Admin.WebApp.Models
@using FootballRadar.Web.Utilities
@model IEnumerable<NationalTeamViewModel>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Nationalteams (@Model.Count())</h2>

    <a class="btn btn-primary"
       href="@Url.Action(nameof(NationalTeamController.CreateNationalTeam), ControllerName.For<NationalTeamController>())">
        + Create NationalTeam
    </a>
</div>

<table class="table table-striped table-hover align-middle">
<thead class="table-light">
    <tr>
        <th>Name</th>
        <th>Country</th>
        <th>Level</th>
        <th style="width: 120px;"></th>
    </tr>
</thead>
<tbody>
    @foreach (var nationalTeam in Model)
    {
        <tr>
            <td>
                <strong>@nationalTeam.Name</strong>
                <td>@nationalTeam.Country</td>
                <td>@nationalTeam.Level</td>
            <td class="text-end">
                    <form method="post" action="@Url.Action(nameof(NationalTeamController.Delete), ControllerName.For<NationalTeamController>())" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@nationalTeam.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
    }
</tbody>
</table>
