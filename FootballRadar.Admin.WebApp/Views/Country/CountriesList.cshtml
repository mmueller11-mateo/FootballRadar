@using FootballRadar.Admin.WebApp.Controllers
@using FootballRadar.Admin.WebApp.Models
@model IReadOnlyCollection<CountryViewModel>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Countries (@Model.Count())</h2>
    <a class="btn btn-primary"
       href="@Url.Action(nameof(CountryController.CreateCountry), nameof(CountryController).Replace("Controller", ""))">
        + Create Country
    </a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Name</th>
            <th style="width: 120px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var country in Model)
        {
            <tr>
                <td>
                    <strong>@country.Name</strong>
                </td>
                <td class="text-end">
                    <form method="post" action="@Url.Action(nameof(CountryController.Delete), nameof(CountryController).Replace("Controller", ""))" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@country.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>