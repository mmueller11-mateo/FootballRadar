@using FootballRadar.WebApp.Controllers
@using FootballRadar.Web.Utilities
@model FootballRadar.WebApp.Models.RanglisteViewModel
@{
    ViewData["Title"] = "Rangliste";
}

<div class="container mt-4">
    <h2>🏆 Rangliste</h2>

    @if (!Model.Entries.Any())
    {
        <p class="text-muted">Noch keine Punkte vergeben.</p>
    }
    else
    {
        <table class="table table-striped mt-3">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th class="text-center">Tipps</th>
                    <th class="text-center">Punkte</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Entries.Count; i++)
                {
                    var entry = Model.Entries[i];
                    <tr>
                        <td>
                            @if (i == 0)
                            {
                                <span>🥇</span>
                            }
                            else if (i == 1)
                            {

                                <span>🥈</span>
                            }
                            else if (i == 2)
                            {

                                <span>🥉</span>
                            }
                            else
                            {

                                <span>@(i + 1)</span>
                            }
                        </td>
                        <td>@entry.TipperName</td>
                        <td class="text-center">@entry.TipsCount</td>
                        <td class="text-center"><strong>@entry.TotalPoints</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-4">
        <a href="@Url.Action(nameof(TippSpielHomeController.Index), ControllerName.For<TippSpielHomeController>())"
           class="btn btn-outline-primary">
            ← Zurück zur Startseite
        </a>
    </div>
</div>