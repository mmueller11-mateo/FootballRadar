@model FootballRadar.WebApp.Models.BonusIndexViewModel
@{
    ViewData["Title"] = "Bonusfragen auflösen (Admin)";
}

<h2>Bonusfragen auflösen</h2>
<p class="text-muted">Wähle die richtige Antwort — Punkte werden automatisch an alle richtigen Tipper vergeben.</p>

<div class="bonus-list">
    @foreach (var item in Model.QuestionsWithTips)
    {
        var q = item.Question;

        <div class="card mb-3 @(q.IsResolved ? "border-success" : "")">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <h6 class="card-title mb-1">@q.QuestionText</h6>
                    @if (q.IsResolved)
                    {
                        var resolvedTeam = Model.Teams.FirstOrDefault(t => t.Id == q.CorrectAnswerTeamId)?.Name ?? "–";
                        <span class="badge bg-success">Aufgelöst: @resolvedTeam</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Offen</span>
                    }
                </div>

                @if (!q.IsResolved)
                {
                    <div class="mt-2 d-flex gap-2 align-items-center">
                        <select class="form-select form-select-sm w-auto resolve-select"
                                data-question-id="@q.Id">
                            <option value="">– Richtige Antwort wählen –</option>
                            @foreach (var team in Model.Teams)
                            {
                                <option value="@team.Id">@team.Name</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-success resolve-btn"
                                data-question-id="@q.Id">
                            Auflösen & Punkte vergeben
                        </button>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.resolve-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const questionId = btn.dataset.questionId;
                const select = document.querySelector(`.resolve-select[data-question-id="${questionId}"]`);
                const teamId = select.value;

                if (!teamId) {
                    alert('Bitte die richtige Mannschaft auswählen.');
                    return;
                }

                if (!confirm('Punkte vergeben? Dies kann nicht rückgängig gemacht werden.'))
                    return;

                const response = await fetch('/Bonus/ResolveQuestion', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ bonusQuestionId: questionId, correctAnswerTeamId: teamId })
                });

                if (response.ok) {
                    location.reload();
                } else {
                    alert('Fehler beim Auflösen.');
                }
            });
        });
    </script>
}
