@model FootballRadar.WebApp.Models.KoMatchViewModel

@{
    var cardClass = Model.IsTipped ? "border-success" : (Model.IsReady ? "border-0" : "border-0 opacity-75");
}

<div class="card shadow-sm @cardClass h-100">
    <div class="card-body p-3">

        @* Datum *@
        <div class="text-muted small mb-2">
            @Model.KickoffUtc.LocalDateTime.ToString("dd.MM.yyyy HH:mm")
        </div>

        @* Heim *@
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="d-flex align-items-center gap-2">
                @if (!string.IsNullOrEmpty(Model.HomeLogoUrl))
                {
                    <img src="@Model.HomeLogoUrl" style="width:24px;height:24px;object-fit:contain;" />
                }
                <span class="fw-semibold">
                    @(Model.HomeTeam ?? Model.HomeQualificationCode ?? "?")
                </span>
            </div>
            @if (Model.IsTipped)
            {
                <span class="fw-bold">@Model.PredictedHomeGoals</span>
            }
        </div>

        @* Gast *@
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center gap-2">
                @if (!string.IsNullOrEmpty(Model.AwayLogoUrl))
                {
                    <img src="@Model.AwayLogoUrl" style="width:24px;height:24px;object-fit:contain;" />
                }
                <span class="fw-semibold">
                    @(Model.AwayTeam ?? Model.AwayQualificationCode ?? "?")
                </span>
            </div>
            @if (Model.IsTipped)
            {
                <span class="fw-bold">@Model.PredictedAwayGoals</span>
            }
        </div>

        @* Tipp-Sieger Badge *@
        @if (Model.IsTipped && Model.PredictedWinnerId.HasValue)
        {
            var winnerName = Model.PredictedWinnerId == Model.HomeTeamId
                ? Model.HomeTeam
                : Model.AwayTeam;
            <div class="d-flex align-items-center gap-1 mb-2">
                <i class="bi bi-trophy-fill text-warning small"></i>
                <span class="small text-success fw-semibold">@winnerName</span>
            </div>
        }

        @* Button *@
        @if (Model.IsReady)
        {
            <a href="/TippMatch/KoTip/@Model.FixtureId"
               class="btn btn-sm w-100 @(Model.IsTipped ? "btn-outline-success" : "btn-outline-primary")">
                @(Model.IsTipped ? "Tipp ändern" : "Tippen")
            </a>
        }
        else
        {
            <button class="btn btn-sm btn-outline-secondary w-100" disabled>
                Noch nicht bekannt
            </button>
        }

    </div>
</div>