@model FootballRadar.WebApp.Models.KoBracketViewModel

<link rel="stylesheet" href="~/css/ko-bracket.css" />

<div class="bracket-scroll">
    <div id="ko-bracket" style="display:flex; gap:0; align-items:stretch; min-width:1100px;">
    </div>
</div>

<div class="modal fade" id="ko-modal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Tipp eingeben</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modal-kickoff" class="text-center small text-muted mb-3"></div>
                <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
                    <div class="d-flex flex-column align-items-center gap-1">
                        <img id="modal-home-logo" style="width:32px;height:32px;object-fit:contain" />
                        <span id="modal-home-name" class="fw-semibold text-center" style="font-size:13px;max-width:80px"></span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <input id="modal-home-goals" type="number" min="0" max="20" class="form-control text-center" style="width:56px" />
                        <span class="fw-bold fs-5">:</span>
                        <input id="modal-away-goals" type="number" min="0" max="20" class="form-control text-center" style="width:56px" />
                    </div>
                    <div class="d-flex flex-column align-items-center gap-1">
                        <img id="modal-away-logo" style="width:32px;height:32px;object-fit:contain" />
                        <span id="modal-away-name" class="fw-semibold text-center" style="font-size:13px;max-width:80px"></span>
                    </div>
                </div>
                <div id="modal-error" style="display:none" class="alert alert-warning py-1 px-2 small text-center">
                    Kein Unentschieden möglich – bitte einen Gewinner bestimmen.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Abbrechen</button>
                <button id="modal-save" type="button" class="btn btn-primary btn-sm">Speichern</button>
            </div>
        </div>
    </div>
</div>
<script id="bracket-data" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
            rounds = new
            {
                    r32_L = Model.RoundOf32.Take(8).Select(m => new
                    {
                            fixtureId = m.FixtureId,
                            home = m.HomeTeam ?? m.HomeQualificationCode ?? "?",
                            away = m.AwayTeam ?? m.AwayQualificationCode ?? "?",
                            homeLogo = m.HomeLogoUrl,
                            awayLogo = m.AwayLogoUrl,
                            homeId = m.HomeTeamId,
                            awayId = m.AwayTeamId,
                            winnerId = m.PredictedWinnerId,
                            predictedHomeGoals = m.PredictedHomeGoals,
                            predictedAwayGoals = m.PredictedAwayGoals,
                            kickoffUtc = m.KickoffUtc
                    }),
                    r32_R = Model.RoundOf32.Skip(8).Select(m => new
                    {
                            fixtureId = m.FixtureId,
                            home = m.HomeTeam ?? m.HomeQualificationCode ?? "?",
                            away = m.AwayTeam ?? m.AwayQualificationCode ?? "?",
                            homeLogo = m.HomeLogoUrl,
                            awayLogo = m.AwayLogoUrl,
                            homeId = m.HomeTeamId,
                            awayId = m.AwayTeamId,
                            winnerId = m.PredictedWinnerId,
                            predictedHomeGoals = m.PredictedHomeGoals,
                            predictedAwayGoals = m.PredictedAwayGoals,
                            kickoffUtc = m.KickoffUtc

                    }),
                    r16_L = Model.RoundOf16.Take(4).Select(m => new
                    {
                            fixtureId = m.FixtureId,
                            home = m.HomeTeam ?? "?",
                            away = m.AwayTeam ?? "?",
                            homeLogo = m.HomeLogoUrl,
                            awayLogo = m.AwayLogoUrl,
                            homeId = m.HomeTeamId,
                            awayId = m.AwayTeamId,
                            winnerId = m.PredictedWinnerId,
                            predictedHomeGoals = m.PredictedHomeGoals,
                            predictedAwayGoals = m.PredictedAwayGoals,
                            kickoffUtc = m.KickoffUtc

                    }),
                    r16_R = Model.RoundOf16.Skip(4).Select(m => new
                    {
                            fixtureId = m.FixtureId,
                            home = m.HomeTeam ?? "?",
                            away = m.AwayTeam ?? "?",
                            homeLogo = m.HomeLogoUrl,
                            awayLogo = m.AwayLogoUrl,
                            homeId = m.HomeTeamId,
                            awayId = m.AwayTeamId,
                            winnerId = m.PredictedWinnerId,
                            predictedHomeGoals = m.PredictedHomeGoals,
                            predictedAwayGoals = m.PredictedAwayGoals,
                            kickoffUtc = m.KickoffUtc

                    }),
                    qf_L = Model.QuarterFinals.Take(2).Select(m => new
                    {
                            fixtureId = m.FixtureId,
                            home = m.HomeTeam ?? "?",
                            away = m.AwayTeam ?? "?",
                            homeLogo = m.HomeLogoUrl,
                            awayLogo = m.AwayLogoUrl,
                            homeId = m.HomeTeamId,
                            awayId = m.AwayTeamId,
                            winnerId = m.PredictedWinnerId,
                            predictedHomeGoals = m.PredictedHomeGoals,
                            predictedAwayGoals = m.PredictedAwayGoals,
                            kickoffUtc = m.KickoffUtc

                    }),
                    qf_R = Model.QuarterFinals.Skip(2).Select(m => new
                    {
                            fixtureId = m.FixtureId,
                            home = m.HomeTeam ?? "?",
                            away = m.AwayTeam ?? "?",
                            homeLogo = m.HomeLogoUrl,
                            awayLogo = m.AwayLogoUrl,
                            homeId = m.HomeTeamId,
                            awayId = m.AwayTeamId,
                            winnerId = m.PredictedWinnerId,
                            predictedHomeGoals = m.PredictedHomeGoals,
                            predictedAwayGoals = m.PredictedAwayGoals,
                            kickoffUtc = m.KickoffUtc

                    }),
                    sf_L = Model.SemiFinals.Take(1).Select(m => new
                    {
                            fixtureId = m.FixtureId,
                            home = m.HomeTeam ?? "?",
                            away = m.AwayTeam ?? "?",
                            homeLogo = m.HomeLogoUrl,
                            awayLogo = m.AwayLogoUrl,
                            homeId = m.HomeTeamId,
                            awayId = m.AwayTeamId,
                            winnerId = m.PredictedWinnerId,
                            predictedHomeGoals = m.PredictedHomeGoals,
                            predictedAwayGoals = m.PredictedAwayGoals,
                            kickoffUtc = m.KickoffUtc

                    }),
                    sf_R = Model.SemiFinals.Skip(1).Select(m => new
                    {
                            fixtureId = m.FixtureId,
                            home = m.HomeTeam ?? "?",
                            away = m.AwayTeam ?? "?",
                            homeLogo = m.HomeLogoUrl,
                            awayLogo = m.AwayLogoUrl,
                            homeId = m.HomeTeamId,
                            awayId = m.AwayTeamId,
                            winnerId = m.PredictedWinnerId,
                            predictedHomeGoals = m.PredictedHomeGoals,
                            predictedAwayGoals = m.PredictedAwayGoals,
                            kickoffUtc = m.KickoffUtc

                    }),
                    final = Model.Final == null ? new object[] { } : new[] { new {
                            fixtureId = Model.Final.FixtureId,
                            home = Model.Final.HomeTeam ?? "?",
                            away = Model.Final.AwayTeam ?? "?",
                            homeLogo = Model.Final.HomeLogoUrl,
                            awayLogo = Model.Final.AwayLogoUrl,
                            homeId = Model.Final.HomeTeamId,
                            awayId = Model.Final.AwayTeamId,
                            winnerId = Model.Final.PredictedWinnerId,
                            predictedHomeGoals = Model.Final.PredictedHomeGoals,
                            predictedAwayGoals = Model.Final.PredictedAwayGoals,
                            kickoffUtc = Model.Final.KickoffUtc

                    }},
                    third = Model.ThirdPlace == null ? new object[] { } : new[] { new {
                            fixtureId = Model.ThirdPlace.FixtureId,
                            home = Model.ThirdPlace.HomeTeam ?? "?",
                            away = Model.ThirdPlace.AwayTeam ?? "?",
                            homeLogo = Model.ThirdPlace.HomeLogoUrl,
                            awayLogo = Model.ThirdPlace.AwayLogoUrl,
                            homeId = Model.ThirdPlace.HomeTeamId,
                            awayId = Model.ThirdPlace.AwayTeamId,
                            winnerId = Model.ThirdPlace.PredictedWinnerId,
                            predictedHomeGoals = Model.ThirdPlace.PredictedHomeGoals,
                            predictedAwayGoals = Model.ThirdPlace.PredictedAwayGoals,
                            kickoffUtc = Model.ThirdPlace.KickoffUtc

                    }}
            }
    }))
</script>

<script src="~/js/ko-bracket.js"></script>