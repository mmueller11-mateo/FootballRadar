@model FootballRadar.WebApp.Models.KoBracketViewModel

@{
    var r32 = Model.RoundOf32.ToDictionary(m => m.ApiFixtureId);
    var r16 = Model.RoundOf16.ToDictionary(m => m.ApiFixtureId);
    var qf = Model.QuarterFinals.ToDictionary(m => m.ApiFixtureId);
    var sf = Model.SemiFinals.ToDictionary(m => m.ApiFixtureId);

    var r32L = new[] { 74, 77, 73, 75, 83, 84, 81, 82 }.Where(r32.ContainsKey).Select(id => r32[id]).ToList();
    var r32R = new[] { 76, 78, 79, 80, 86, 88, 85, 87 }.Where(r32.ContainsKey).Select(id => r32[id]).ToList();
    var r16L = new[] { 89, 90, 93, 94 }.Where(r16.ContainsKey).Select(id => r16[id]).ToList();
    var r16R = new[] { 91, 92, 95, 96 }.Where(r16.ContainsKey).Select(id => r16[id]).ToList();
    var qfL = new[] { 97, 98 }.Where(qf.ContainsKey).Select(id => qf[id]).ToList();
    var qfR = new[] { 99, 100 }.Where(qf.ContainsKey).Select(id => qf[id]).ToList();
    var sfL = sf.ContainsKey(101) ? sf[101] : null;
    var sfR = sf.ContainsKey(102) ? sf[102] : null;

    object MatchJson(KoMatchViewModel? m) => m == null ? (object)new { } : new
    {
        fixtureId = m.FixtureId,
        home = m.HomeTeam ?? m.HomeQualificationCode ?? "?",
        away = m.AwayTeam ?? m.AwayQualificationCode ?? "?",
        homeLogo = m.HomeLogoUrl,
        awayLogo = m.AwayLogoUrl,
        homeId = m.HomeTeamId,
        awayId = m.AwayTeamId,
        winnerId = m.PredictedWinnerId,
        predictedHomeGoals = m.PredictedHomeGoals,
        predictedAwayGoals = m.PredictedAwayGoals,
        kickoffUtc = m.KickoffUtc
    };
}

<link rel="stylesheet" href="~/css/ko-bracket.css" />

<div class="bracket-scroll">
    <div id="ko-bracket" style="display:flex; gap:0; align-items:stretch; min-width:1100px;"></div>
</div>

<div class="modal fade" id="ko-modal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">Tipp eingeben</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modal-kickoff" class="text-center small text-muted mb-3"></div>
                <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
                    <div class="d-flex flex-column align-items-center gap-1">
                        <img id="modal-home-logo" style="width:32px;height:32px;object-fit:contain" />
                        <span id="modal-home-name" class="fw-semibold text-center" style="font-size:13px;max-width:80px"></span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <input id="modal-home-goals" type="number" min="0" max="20" class="form-control text-center" style="width:56px" />
                        <span class="fw-bold fs-5">:</span>
                        <input id="modal-away-goals" type="number" min="0" max="20" class="form-control text-center" style="width:56px" />
                    </div>
                    <div class="d-flex flex-column align-items-center gap-1">
                        <img id="modal-away-logo" style="width:32px;height:32px;object-fit:contain" />
                        <span id="modal-away-name" class="fw-semibold text-center" style="font-size:13px;max-width:80px"></span>
                    </div>
                </div>
                <div id="modal-error" style="display:none" class="alert alert-warning py-1 px-2 small text-center">
                    Kein Unentschieden möglich – bitte einen Gewinner bestimmen.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Abbrechen</button>
                <button id="modal-save" type="button" class="btn btn-primary btn-sm">Speichern</button>
            </div>
        </div>
    </div>
</div>

<script id="bracket-data" type="application/json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
            rounds = new
            {
                    r32_L = r32L.Select(m => MatchJson(m)),
                    r32_R = r32R.Select(m => MatchJson(m)),
                    r16_L = r16L.Select(m => MatchJson(m)),
                    r16_R = r16R.Select(m => MatchJson(m)),
                    qf_L = qfL.Select(m => MatchJson(m)),
                    qf_R = qfR.Select(m => MatchJson(m)),
                    sf_L = sfL != null ? new[] { MatchJson(sfL) } : Array.Empty<object>(),
                    sf_R = sfR != null ? new[] { MatchJson(sfR) } : Array.Empty<object>(),
                    final = Model.Final != null ? new[] { MatchJson(Model.Final) } : Array.Empty<object>(),
                    third = Model.ThirdPlace != null ? new[] { MatchJson(Model.ThirdPlace) } : Array.Empty<object>(),
            }
    }))
</script>

<script src="~/js/ko-bracket.js"></script>