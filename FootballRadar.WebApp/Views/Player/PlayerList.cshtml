@using FootballRadar.WebApp.Controllers
@model FootballRadar.WebApp.Models.TeamPlayersViewModel

<h2 class="mb-3">Squad</h2>

<!-- Saison-Tabs -->
<ul class="nav nav-pills mb-4">
    @foreach (var s in Model.AvailableSeasons)
    {
        <li class="nav-item">
            <a class="nav-link @(s == Model.Season ? "active" : "")"
               href="@Url.Action(nameof(PlayerController.PlayerList), ControllerName.For<PlayerController>(), new { apiTeamId = Model.ApiTeamId, season = s })">
                @s / @(s + 1)
            </a>
        </li>
    }
</ul>

<!-- Spieler-Grid -->
<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var player in Model.Players)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                @if (player.Photo != null)
                {
                    <img src="@player.Photo" class="card-img-top p-3" style="height:180px; object-fit:contain;" alt="@player.Name" />
                }
                <div class="card-body">
                    <h6 class="card-title mb-1">@player.FirstName @player.LastName</h6>
                    <small class="text-muted">@player.Name</small>
                    <p class="mt-2 mb-0 small">
                        🎂 @player.BirthDate.ToString("dd.MM.yyyy")
                    </p>
                </div>
            </div>
        </div>
    }
</div>