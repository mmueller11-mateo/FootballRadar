@model FootballRadar.Business.Entities.Betting.UserProfile

<div class="container mt-4">
    <h2 class="mb-4">My Profile</h2>

    @* Profile Header *@
    <div class="row g-3 mb-5">
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    @if (Model.ProfilePictureUrl != null)
                    {
                        <img src="@Model.ProfilePictureUrl" class="rounded-circle mb-2" height="60" width="60" style="object-fit:cover" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto mb-2" style="width:60px;height:60px">
                            <span class="text-white fw-bold fs-4">@Model.Nickname.FirstOrDefault()</span>
                        </div>
                    }
                    <h5 class="mb-0">@Model.Nickname</h5>
                    <small class="text-muted">Nickname</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm border-info">
                <div class="card-body">
                    <h3 class="mb-0 text-info">@Model.Wallet?.Credits.ToString("N2")</h3>
                    <small class="text-muted">Credits</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm border-success">
                <div class="card-body">
                    <h3 class="mb-0 text-success">@Model.Wallet?.Credits.ToString("N2")</h3>
                    <small class="text-muted">Balance</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h3 class="mb-0">@Model.ActiveBets.Count</h3>
                    <small class="text-muted">Active Bets</small>
                </div>
            </div>
        </div>
    </div>

    @* Edit Profile *@
    <h4 class="mb-3">Edit Profile</h4>
    <div class="card shadow-sm mb-5">
        <div class="card-body">
            <form method="post" asp-action="UpdateProfile">
                <input type="hidden" name="userId" value="@Model.UserId" />
                <div class="mb-3">
                    <label class="form-label">Nickname</label>
                    <input type="text" name="nickname" class="form-control" value="@Model.Nickname" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Profile Picture URL</label>
                    <input type="url" name="profilePictureUrl" class="form-control" value="@Model.ProfilePictureUrl" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </form>
        </div>
    </div>

    @* Notification Preferences *@
    <h4 class="mb-3">Notification Preferences</h4>
    <div class="card shadow-sm mb-5">
        <div class="card-body">
            @{
                // Jeder Eintrag entspricht einer Event-Klasse aus FootballRadar.Abstractions.Events.
                // Key im Dictionary = typeof(TEvent).FullName (siehe PushNotificationService.Handle<TEvent>).
                // Label/Beschreibung sind rein für die Anzeige.
                var eventTypes = new (string FullName, string Label, string Description, string Icon)[]
                {
                    ("FootballRadar.Abstractions.Events.CreditDeposited", "Credit Deposited", "When credits are added to your wallet", "bi-cash-coin"),
                    ("FootballRadar.Abstractions.Events.TransferConfirmed", "Transfer Confirmed", "When a transfer you follow is confirmed", "bi-arrow-left-right"),
                    ("FootballRadar.Abstractions.Events.TransferRumorReported", "Transfer Rumor Reported", "When a new transfer rumor is reported", "bi-megaphone"),
                    ("FootballRadar.Abstractions.Events.PredictionMarketClosed", "Prediction Market Closed", "When a prediction market you bet on closes", "bi-flag"),
                };
                var prefs = Model.EventNotificationPreferences;
            }

            @foreach (var eventType in eventTypes)
            {
                var isEnabled = prefs.SingleOrDefault(x => x.EventType == eventType.FullName && x.IsEnabled) is not null;

                <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi @eventType.Icon text-secondary"></i>
                        <div>
                            <div>@eventType.Label</div>
                            <small class="text-muted">@eventType.Description</small>
                        </div>
                    </div>
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input notification-toggle" type="checkbox" role="switch"
                               data-event-type="@eventType.FullName"
                               id="pref_@eventType.FullName"
                               style="width: 2.5em; height: 1.4em; cursor: pointer;"
                        @(isEnabled ? "checked" : "") />
                    </div>
                </div>
            }
        </div>
    </div>

    <script>
            document.querySelectorAll('.notification-toggle').forEach(function (toggle) {
                toggle.addEventListener('change', function () {
                    fetch('@Url.Action("SetNotificationPreference", "Profile")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            userId: '@Model.UserId',
                            eventType: toggle.dataset.eventType,
                            isEnabled: toggle.checked
                        })
                    }).catch(function () {
                        // Bei Fehler den Toggle zurücksetzen
                        toggle.checked = !toggle.checked;
                    });
                });
            });
    </script>

    @* Active Bets *@
    <h4 class="mb-3">Active Bets <span class="badge bg-secondary">@Model.ActiveBets.Count</span></h4>
    @if (!Model.ActiveBets.Any())
    {
        <p class="text-muted mb-5">No active bets.</p>
    }
    else
    {
        <div class="row g-3 mb-5">
            @foreach (var bet in Model.ActiveBets)
            {
                <div class="col-12 col-md-6">
                    <div class="card shadow-sm border-warning">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <span>Market: <strong>@bet.PredictionMarketId</strong></span>
                                <span>Stake: <strong>@bet.Credits.ToString("N2")</strong></span>
                            </div>
                            <small class="text-muted">Placed: @bet.PlacedAt.ToString("dd.MM.yyyy HH:mm")</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* Transaction History *@
    <h4 class="mb-3">Transaction History <span class="badge bg-secondary">@Model.RecentTransactions.Count</span></h4>
    @if (!Model.RecentTransactions.Any())
    {
        <p class="text-muted">No transactions yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th class="text-end">Credits</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in Model.RecentTransactions)
                    {
                        var statusClass = tx.Status.ToString() == "Completed" ? "text-success" :
                                          tx.Status.ToString() == "Failed" ? "text-danger" : "text-warning";
                        <tr>
                            <td>@tx.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@tx.Type</td>
                            <td class="@statusClass">@tx.Status</td>
                            <td class="text-end">@tx.Credits.ToString("N2")</td>
                            <td class="text-end">@tx.Amount.ToString()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
