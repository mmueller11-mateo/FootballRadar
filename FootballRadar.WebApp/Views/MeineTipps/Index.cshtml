@model FootballRadar.WebApp.Models.MeineTippsViewModel
@{
    ViewData["Title"] = "Meine Tipps";
    var groupTips = Model.Entries.Where(e => !e.IsKoMatch).ToList();
    var koTips = Model.Entries.Where(e => e.IsKoMatch).ToList();
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4">🎯 Meine Tipps</h2>

    <!-- Statistik-Karten -->
    <div class="row mb-5">
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Gesamtpunkte</h5>
                    <h2 class="text-primary fw-bold">@Model.TotalPoints</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Abgegebene Tipps</h5>
                    <h2>@Model.TippedCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Ausgewertete Tipps</h5>
                    <h2>@Model.SettledCount</h2>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Entries.Any())
    {
        <p class="text-muted">Du hast noch keine Tipps abgegeben.</p>
    }
    else
    {
        <!-- ===== GRUPPENPHASE ===== -->
        @if (groupTips.Any())
        {
            <h4 class="fw-semibold mb-3">Gruppenphase</h4>
            <table class="table table-hover mb-5">
                <thead class="table-light">
                    <tr>
                        <th>Spiel</th>
                        <th class="text-center">Gruppe</th>
                        <th class="text-center">Datum</th>
                        <th class="text-center">Dein Tipp</th>
                        <th class="text-center">Resultat</th>
                        <th class="text-center">Punkte</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in groupTips)
                    {
                        <tr>
                            <td>@entry.HomeTeam – @entry.AwayTeam</td>
                            <td class="text-center"><span class="badge bg-secondary">@(entry.WmGroup ?? "-")</span></td>
                            <td class="text-center">@entry.KickoffUtc.ToLocalTime().ToString("dd.MM.yy HH:mm")</td>
                            <td class="text-center fw-bold">@entry.PredictedHome : @entry.PredictedAway</td>
                            <td class="text-center">
                                @if (entry.ActualHome.HasValue)
                                {
                                    <span>@entry.ActualHome : @entry.ActualAway</span>
                                }
                                else
                                {
                                    <span class="text-muted">–</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (entry.Points == null)
                                {
                                    <span class="text-muted">–</span>
                                }
                                else if (entry.Points > 0)
                                {
                                    <span class="badge bg-success">@entry.Points</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">0</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <!-- ===== K.O.-PHASE ===== -->
        @if (koTips.Any())
        {
            <h4 class="fw-semibold mb-3">K.O.-Phase</h4>
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Spiel</th>
                        <th class="text-center">Runde</th>
                        <th class="text-center">Datum</th>
                        <th class="text-center">Dein Sieger-Tipp</th>
                        <th class="text-center">Echter Sieger</th>
                        <th class="text-center">Punkte</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in koTips)
                    {
                        <tr>
                            <td>@entry.HomeTeam – @entry.AwayTeam</td>
                            <td class="text-center"><span class="badge bg-dark">@(entry.WmGroup ?? "KO")</span></td>
                            <td class="text-center">@entry.KickoffUtc.ToLocalTime().ToString("dd.MM.yy HH:mm")</td>
                            <td class="text-center fw-bold">
                                @if (!string.IsNullOrEmpty(entry.PredictedWinnerName))
                                {
                                    <span>🏆 @entry.PredictedWinnerName</span>
                                }
                                else
                                {
                                    <span class="text-muted">–</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(entry.ActualWinnerName))
                                {
                                    <span>@entry.ActualWinnerName</span>
                                }
                                else
                                {
                                    <span class="text-muted">–</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (entry.Points == null)
                                {
                                    <span class="text-muted">–</span>
                                }
                                else if (entry.Points > 0)
                                {
                                    <span class="badge bg-success">@entry.Points</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">0</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>