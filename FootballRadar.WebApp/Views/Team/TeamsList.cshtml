@model FootballRadar.WebApp.Models.StandingsViewModel
<form method="get" class="mb-3 d-flex gap-2 align-items-center">
    <input type="hidden" name="leagueId" value="@Model.LeagueId" />
    <select name="season" class="form-select w-auto">
        @foreach (var year in Model.AvailableSeasons)
        {
            @if (Model.Season == year)
            {
                <option value="@year" selected>@year</option>
            }
            else
            {
                <option value="@year">@year</option>
            }
        }
    </select>
    <button type="submit" class="btn btn-primary">Go</button>
</form>
<table class="table table-striped table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>#</th>
            <th>Logo</th>
            <th>Team</th>
            <th>MP</th>
            <th>W</th>
            <th>D</th>
            <th>L</th>
            <th>Goals</th>
            <th>GD</th>
            <th>Pts</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var standing in Model.Standings)
        {
            <tr>
                <td>@standing.Rank</td>
                <td><img src="@standing.Team.Logo" width="25" /></td>
                <td>@standing.Team.Name</td>
                <td>@standing.All.Played</td>
                <td>@standing.All.Win</td>
                <td>@standing.All.Draw</td>
                <td>@standing.All.Lose</td>
                <td>@standing.All.Goals.For:@standing.All.Goals.Against</td>
                <td>@standing.GoalsDiff</td>
                <td><strong>@standing.Points</strong></td>
            </tr>
        }
    </tbody>
</table>