@using FootballRadar.TippSpiel.WebApp.Controllers
@model FootballRadar.TippSpiel.WebApp.Models.EnterNameViewModel
@{
    ViewData["Title"] = "Name eingeben";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h4 class="text-center mb-4">📋 Meine Tipps</h4>
                    <p class="text-center text-muted">Gib deinen Namen ein um deine Tipps zu sehen.</p>
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Dein Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Name eingeben..." autofocus />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                        <button type="submit" class="btn btn-primary w-100">Weiter</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>