@using FootballRadar.TippSpiel.WebApp.Controllers
@using FootballRadar.Web.Utilities
@model FootballRadar.TippSpiel.WebApp.Models.MeineTippsViewModel
@{
    ViewData["Title"] = "Meine Tipps";
}

<div class="container mt-4">
    <h2>📋 Meine Tipps</h2>
    <p class="text-muted">Eingeloggt als: <strong>@Model.TipperName</strong></p>

    @if (!Model.Tips.Any())
    {
        <p class="text-muted">Du hast noch keine Tipps abgegeben.</p>
    }
    else
    {
        <table class="table table-striped mt-3">
            <thead>
                <tr>
                    <th>Spiel</th>
                    <th>Phase</th>
                    <th class="text-center">Datum</th>
                    <th class="text-center">Dein Tipp</th>
                    <th class="text-center">Resultat</th>
                    <th class="text-center">Punkte</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tip in Model.Tips)
                {
                    <tr>
                        <td>@tip.HomeTeam vs @tip.AwayTeam</td>
                        <td>@tip.Phase</td>
                        <td class="text-center">@tip.KickoffUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-center">@tip.PredictedHome : @tip.PredictedAway</td>
                        <td class="text-center">
                            @if (tip.HomeScore.HasValue && tip.AwayScore.HasValue)
                            {
                                <span>@tip.HomeScore : @tip.AwayScore</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (tip.Points.HasValue)
                            {
                                @if (tip.Points == 3)
                                {
                                    <span class="badge bg-success">3</span>
                                }
                                else if (tip.Points == 2)
                                {
                                    <span class="badge bg-primary">2</span>
                                }
                                else if (tip.Points == 1)
                                {
                                    <span class="badge bg-warning text-dark">1</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">0</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a href="@Url.Action(nameof(HomeController.Index), ControllerName.For<HomeController>())">Zurück zur Startseite</a>
    </div>
</div>