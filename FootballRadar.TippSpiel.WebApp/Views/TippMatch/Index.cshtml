@using FootballRadar.TippSpiel.WebApp.Controllers
@using FootballRadar.Web.Utilities
@model FootballRadar.TippSpiel.WebApp.Models.TippMatchIndexViewModel
@{
    ViewData["Title"] = "Tippspiel – Gruppen";
}

<div class="container mt-4">
    <h2>⚽ WM 2026 – Gruppenübersicht</h2>

    @if (Model.TipperName != null)
    {
        <p class="text-muted mb-4">Eingeloggt als: <strong>@Model.TipperName</strong></p>
    }

    @if (!Model.Groups.Any())
    {
        <p class="text-muted">Keine Gruppenspiele vorhanden.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var group in Model.Groups)
            {
                <div class="col">
                    <div class="card shadow-sm h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <strong>@group.GroupName</strong>
                            <a href="@Url.Action(nameof(TippMatchController.Group), ControllerName.For<TippMatchController>(), new { groupName = group.GroupName })"
                               class="btn btn-sm btn-outline-primary">
                                Zur Gruppe →
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Team</th>
                                        <th class="text-center">Sp</th>
                                        <th class="text-center">S</th>
                                        <th class="text-center">U</th>
                                        <th class="text-center">N</th>
                                        <th class="text-center">Tore</th>
                                        <th class="text-center">Diff</th>
                                        <th class="text-center fw-bold">Pkt</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in group.Standings)
                                    {
                                        <tr>
                                            <td>@row.Team</td>
                                            <td class="text-center">@row.Played</td>
                                            <td class="text-center">@row.Won</td>
                                            <td class="text-center">@row.Drawn</td>
                                            <td class="text-center">@row.Lost</td>
                                            <td class="text-center">@row.GoalsFor:@row.GoalsAgainst</td>
                                            <td class="text-center">@row.GoalDifference</td>
                                            <td class="text-center fw-bold">@row.Points</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
