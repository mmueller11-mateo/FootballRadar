@using FootballRadar.TippSpiel.WebApp.Controllers
@using FootballRadar.Web.Utilities
@model FootballRadar.TippSpiel.WebApp.Models.TippMatchIndexViewModel
@{
    ViewData["Title"] = "Tippspiel";
}

<div class="container mt-4">
    <h2>⚽ Kommende Spiele</h2>

    @if (Model.TipperName != null)
    {
        <p class="text-muted">Eingeloggt als: <strong>@Model.TipperName</strong></p>
    }

    @foreach (var match in Model.Matches)
    {
        var existingTip = Model.ExistingTips.FirstOrDefault(t => t.MatchId == match.Id);

        <div class="card mb-3 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="badge bg-secondary">@match.Phase</span>
                        <small class="text-muted ms-2">@match.KickoffUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                    </div>
                </div>
                <div class="text-center my-3">
                    <h4>@match.HomeTeam <span class="text-muted">vs</span> @match.AwayTeam</h4>
                </div>
                <div class="text-center">
                    @if (existingTip != null)
                    {
                        <span class="badge bg-success me-2">Dein Tipp: @existingTip.PredictedHome : @existingTip.PredictedAway</span>
                        <a href="@Url.Action(nameof(TippMatchController.Tip), ControllerName.For<TippMatchController>(), new { matchId = match.Id })" class="btn btn-sm btn-outline-primary">Ändern</a>
                    }
                    else
                    {
                        <a href="@Url.Action(nameof(TippMatchController.Tip), ControllerName.For<TippMatchController>(), new { matchId = match.Id })" class="btn btn-primary">Jetzt tippen</a>
                    }
                </div>
            </div>
        </div>
    }

    @if (!Model.Matches.Any())
    {
        <p class="text-muted">Keine kommenden Spiele vorhanden.</p>
    }
</div>