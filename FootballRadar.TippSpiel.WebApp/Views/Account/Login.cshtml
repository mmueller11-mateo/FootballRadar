@model FootballRadar.TippSpiel.WebApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Anmelden";
}

<div class="container mt-5" style="max-width: 400px">
    <h3 class="mb-4">🔐 Anmelden</h3>
    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Name</label>
            <input asp-for="Name" class="form-control" autofocus />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label">Passwort</label>
            <input asp-for="Password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100">Anmelden</button>
    </form>
    <hr />
    <p class="text-center mb-0">Noch kein Konto? <a asp-action="Register">Registrieren</a></p>
</div>